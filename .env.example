# Environment Variables Template
# Copy this file to .env.local and fill in the actual values from your Supabase project

# ============================================================================
# SUPABASE CONFIGURATION
# ============================================================================

# Get these from: Supabase Dashboard > Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# IMPORTANT: Keep this secret! Only use in server-side code (API routes, middleware, etc.)
# Get this from: Supabase Dashboard > Settings > API > Service Role Secret
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ============================================================================
# DATABASE CONFIGURATION (Optional - if using Prisma directly)
# ============================================================================

# Get this from: Supabase Dashboard > Settings > Database > URI
# Format: postgresql://postgres:password@host:port/database
DATABASE_URL=postgresql://postgres:password@your-project.supabase.co:5432/postgres

# ============================================================================
# AUTHENTICATION CONFIGURATION
# ============================================================================

# NextAuth Configuration (if using NextAuth)
NEXTAUTH_SECRET=your-secret-key-here
NEXTAUTH_URL=http://localhost:3000

# OAuth Providers (Optional)
# Google OAuth
GOOGLE_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_SECRET=your-google-client-secret

# GitHub OAuth
GITHUB_ID=your-github-app-id
GITHUB_SECRET=your-github-app-secret

# ============================================================================
# EMAIL CONFIGURATION
# ============================================================================

# SMTP Settings for sending verification emails
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# Email service provider (gmail, sendgrid, mailgun, etc.)
EMAIL_FROM=noreply@yourapp.com
EMAIL_FROM_NAME=AI Budget Tracker

# SendGrid (Alternative email provider)
# SENDGRID_API_KEY=sg_your-sendgrid-api-key

# Mailgun (Alternative email provider)
# MAILGUN_API_KEY=key-your-mailgun-api-key
# MAILGUN_DOMAIN=mail.yourdomain.com

# ============================================================================
# AI/CHATBOT CONFIGURATION
# ============================================================================

# OpenAI API Key (for AI insights and chat)
OPENAI_API_KEY=sk-...

# Or use Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Model selection
AI_MODEL=gpt-4-turbo  # or gpt-3.5-turbo, claude-3-opus, etc.

# ============================================================================
# APPLICATION CONFIGURATION
# ============================================================================

# Node environment
NODE_ENV=development  # development, production, staging

# Application URL
NEXT_PUBLIC_APP_URL=http://localhost:3000

# API Configuration
NEXT_PUBLIC_API_URL=http://localhost:3000/api

# Timezone
NEXT_PUBLIC_TIMEZONE=Asia/Manila

# Currency
NEXT_PUBLIC_CURRENCY=PHP

# ============================================================================
# ANALYTICS & MONITORING (Optional)
# ============================================================================

# Sentry (Error tracking)
NEXT_PUBLIC_SENTRY_DSN=https://your-sentry-dsn@sentry.io/project-id

# Google Analytics
NEXT_PUBLIC_GA_ID=G-XXXXXXXXXX

# Posthog (Analytics)
NEXT_PUBLIC_POSTHOG_KEY=phc_...

# ============================================================================
# EXTERNAL SERVICES (Optional)
# ============================================================================

# Bank integration APIs (if needed)
PLAID_CLIENT_ID=your-plaid-client-id
PLAID_SECRET=your-plaid-secret

# PDF Generation
PUPPETEER_SKIP_CHROMIUM_DOWNLOAD=true

# ============================================================================
# DEVELOPMENT SETTINGS
# ============================================================================

# Enable debug logging
DEBUG=true

# API request timeout (in milliseconds)
API_TIMEOUT=30000

# Max upload file size (in bytes)
MAX_FILE_SIZE=5242880  # 5MB

# ============================================================================
# FEATURE FLAGS (Optional)
# ============================================================================

# Enable/disable features
ENABLE_NOTIFICATIONS=true
ENABLE_EXPORT=true
ENABLE_REPORTS=true
ENABLE_BUDGET_GOALS=false
ENABLE_DARK_MODE=true

# ============================================================================
# SESSION & SECURITY
# ============================================================================

# Session configuration
SESSION_MAX_AGE=604800  # 7 days in seconds
SESSION_COOKIE_SECURE=true
SESSION_COOKIE_HTTPONLY=true

# CORS Settings
CORS_ORIGIN=http://localhost:3000

# ============================================================================
# INSTRUCTIONS FOR SETUP
# ============================================================================

# 1. Get Supabase Keys:
#    - Go to https://supabase.com and create a project
#    - Go to Settings > API
#    - Copy "Project URL" to NEXT_PUBLIC_SUPABASE_URL
#    - Copy "anon public" key to NEXT_PUBLIC_SUPABASE_ANON_KEY
#    - Copy "service_role" key to SUPABASE_SERVICE_ROLE_KEY
#
# 2. Setup Email Service:
#    Option A - Gmail:
#      - Go to Google Account > Security
#      - Enable 2-Factor Authentication
#      - Generate "App Password" for Gmail
#      - Use the app password in SMTP_PASSWORD
#    
#    Option B - SendGrid:
#      - Create SendGrid account
#      - Generate API key
#      - Use SENDGRID_API_KEY instead of SMTP settings
#
# 3. Setup OAuth (Optional):
#    - Google: https://console.cloud.google.com/
#    - GitHub: https://github.com/settings/developers
#    - Configure redirect URIs to http://localhost:3000/auth/callback
#
# 4. Setup AI (Optional):
#    - Get API key from OpenAI (https://platform.openai.com/api-keys)
#    - Or from Anthropic (https://console.anthropic.com/)
#
# 5. Copy this file to .env.local and fill in the values
#    DO NOT commit .env.local to git!

# ============================================================================
# NOTES
# ============================================================================

# - Never commit sensitive keys (passwords, API keys, secrets) to version control
# - Keep SUPABASE_SERVICE_ROLE_KEY secret and only use server-side
# - Rotate API keys regularly
# - Use different keys for development, staging, and production
# - Consider using a secrets manager in production
